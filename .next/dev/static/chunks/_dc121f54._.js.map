"use client";

import Link from "next/link";
import { MapPin, Plus, Check, Pencil, Trash2 } from "lucide-react";
import { useState } from "react";

export default function AddressPage() {
  const [selectedAddress, setSelectedAddress] = useState(1);

  const addresses = [
    {
      id: 1,
      name: "Mark Cole",
      phone: "+1 234 567 890",
      address: "4517 Washington Ave, Manchester, Kentucky 39495",
      type: "Home",
    },
    {
      id: 2,
      name: "Mark Cole",
      phone: "+1 987 654 321",
      address: "2118 Thornridge Cir, Syracuse, Connecticut 35624",
      type: "Office",
    },
  ];

  const handleEdit = (e, id) => {
    e.stopPropagation();
    window.location.href = `/profile/address/edit/${id}`;
  };

  const handleDelete = (e, id) => {
    e.stopPropagation();
    // UI only (no logic)
    console.log("Delete address:", id);
  };

  return (
    <div className="max-w-5xl mx-auto px-4 py-10 bg-gradient-to-b from-gray-50 to-white min-h-screen">
      {/* Header */}
      <div className="flex items-center justify-between mb-8">
        <div>
          <h1 className="text-3xl font-bold text-gray-800">Saved Addresses</h1>
          <p className="text-gray-500 mt-1">Select a delivery address</p>
        </div>

        <Link
          href="/profile/address/add"
          className="flex items-center gap-2 bg-[#01A49E] text-white px-5 py-3 rounded-xl transition-all duration-300 hover:bg-[#01857f] hover:shadow-lg active:scale-[0.98]"
        >
          <Plus size={18} />
          Add Address
        </Link>
      </div>

      {/* Address List */}
      <div className="space-y-5">
        {addresses.map((item) => {
          const active = selectedAddress === item.id;

          return (
            <div
              key={item.id}
              onClick={() => setSelectedAddress(item.id)}
              className={`relative bg-white rounded-2xl p-5 border transition-all duration-300 cursor-pointer
              ${
                active
                  ? "border-[#01A49E] shadow-[0_8px_25px_-8px_rgba(1,164,158,0.35)]"
                  : "border-gray-200 hover:border-[#01A49E]/40 hover:shadow-md"
              }`}
            >
              {/* Radio */}
              
              {/* Content */}
              <div className="flex items-start justify-between gap-4">
                <div className="flex items-start gap-4">
                  {/* Icon */}
                  <div
                    className={`min-w-12 h-12 rounded-full flex items-center justify-center transition-colors duration-300
                    ${
                      active
                        ? "bg-[#01A49E]/10 text-[#01A49E]"
                        : "bg-gray-100 text-gray-500"
                    }`}
                  >
                    <MapPin size={22} />
                  </div>

                  {/* Details */}
                  <div className="pr-10">
                    <div className="flex items-center gap-3 mb-2">
                      <span className="text-sm font-medium bg-[#01A49E]/10 text-[#01A49E] px-3 py-1 rounded-full">
                        {item.type}
                      </span>
                    </div>

                    <p className="text-gray-800 leading-7 font-medium">
                      {item.name}, {item.phone}, {item.address}
                    </p>
                  </div>
                </div>

                {/* Actions */}
                <div className="flex items-start gap-2">
                  <button
                    onClick={(e) => handleEdit(e, item.id)}
                    className="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm bg-gray-100 text-gray-700 hover:bg-[#01A49E]/10 hover:text-[#01A49E] transition"
                  >
                    <Pencil size={15} />
                    Edit
                  </button>

                  <button
                    onClick={(e) => handleDelete(e, item.id)}
                    className="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm bg-red-50 text-red-600 hover:bg-red-500 hover:text-white transition"
                  >
                    <Trash2 size={15} />
                    Delete
                  </button>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  );
}
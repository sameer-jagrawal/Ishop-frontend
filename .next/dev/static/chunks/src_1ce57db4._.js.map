"use client";

import { Pencil, Plus, ChevronDown, ChevronUp } from "lucide-react";
import React, { useState } from "react";
import { getProduct } from "@/api_call/api";
import Link from "next/link";
import DeleteBtn from "@/app/components/admin components/DeleteBtn";
import Status from "@/app/components/admin components/Status";
import { FaEye } from "react-icons/fa";

export default async function UserManagementTable() {
  const data = await getProduct();
  const Brands = data?.data;

  return (
    <div className="p-2 md:p-4 min-h-screen bg-gray-50">
      {/* Header */}
      <div className="flex items-center justify-between mb-6 md:mb-8">
        <div>
          <h1 className="text-2xl md:text-3xl font-bold text-gray-800">
            Products
          </h1>

          <p className="text-sm text-gray-500 mt-1">
            Manage all products easily
          </p>
        </div>

        <Link href={"product/add"}>
          <button className="flex items-center gap-2 px-4 md:px-5 py-2.5 bg-black text-white rounded-2xl shadow hover:scale-105 transition-all duration-300 text-sm">
            <Plus size={16} />
            Add Product
          </button>
        </Link>
      </div>

      {/* Table */}
      <div className="bg-white rounded-3xl shadow-xl border border-gray-100 overflow-hidden">
        <div className="overflow-x-auto">
          <table className="min-w-full text-left border-collapse">
            {/* Table Head */}
            <thead className="bg-gray-100 border-b">
              <tr>
                <th className="px-6 py-4 text-xs font-bold text-gray-500 uppercase">
                  Image
                </th>

                <th className="px-6 py-4 text-xs font-bold text-gray-500 uppercase">
                  Product
                </th>

                <th className="px-6 py-4 text-xs font-bold text-gray-500 uppercase">
                  Category
                </th>

                <th className="px-6 py-4 text-xs font-bold text-gray-500 uppercase">
                  Brand
                </th>

                <th className="px-6 py-4 text-xs font-bold text-gray-500 uppercase">
                  Status
                </th>

                <th className="px-6 py-4 text-xs font-bold text-gray-500 uppercase text-center">
                  Actions
                </th>
              </tr>
            </thead>

            {/* Body */}
            <tbody className="divide-y divide-gray-100">
              {Brands.map((user) => (
                <ProductRow key={user._id} user={user} />
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  );
}

/* ========================================================= */
/* Product Row */
/* ========================================================= */

function ProductRow({ user }) {
  const [showStatus, setShowStatus] = useState(false);

  const statusList = [
    {
      field: "status",
      value: user?.status,
    },
    {
      field: "stock",
      value: user?.stock,
    },
    {
      field: "is_home",
      value: user?.is_home,
    },
    {
      field: "is_top",
      value: user?.is_top,
    },
    {
      field: "is_popular",
      value: user?.is_popular,
    },
    {
      field: "is_hot",
      value: user?.is_hot,
    },
    {
      field: "is_best",
      value: user?.is_best,
    },
    {
      field: "is_return",
      value: user?.is_return,
    },
  ];

  return (
    <tr className="hover:bg-gray-50 transition-all duration-200 align-top">
      {/* Image */}
      <td className="px-6 py-5">
        <div className="w-16 h-16 rounded-2xl overflow-hidden border bg-gray-100 shadow-sm">
          <img
            src={`http://localhost:5000/product/${user?.thumbnail}`}
            alt={user?.name}
            className="w-full h-full object-cover hover:scale-105 transition-all duration-300"
          />
        </div>
      </td>

      {/* Product Name */}
      <td className="px-6 py-5">
        <div className="flex flex-col gap-2">
          <h2 className="text-sm font-semibold text-gray-800 line-clamp-2">
            {user?.name}
          </h2>

          <span className="text-xs text-gray-400">
            #{user?._id?.slice(-6)}
          </span>
        </div>
      </td>

      {/* Category */}
      <td className="px-6 py-5">
        <span className="px-3 py-1 bg-indigo-50 text-indigo-700 text-xs rounded-full font-medium border border-indigo-100">
          {user?.categoryId?.name}
        </span>
      </td>

      {/* Brand */}
      <td className="px-6 py-5">
        <span className="px-3 py-1 bg-purple-50 text-purple-700 text-xs rounded-full font-medium border border-purple-100">
          {user?.brandId?.name}
        </span>
      </td>

      {/* Status Toggle */}
      <td className="px-6 py-5 min-w-[260px]">
        {/* Toggle Button */}
        <button
          onClick={() => setShowStatus(!showStatus)}
          className="flex items-center gap-2 px-4 py-2 bg-gray-100 hover:bg-gray-200 rounded-xl text-sm font-medium transition-all"
        >
          Manage Status

          {showStatus ? (
            <ChevronUp size={16} />
          ) : (
            <ChevronDown size={16} />
          )}
        </button>

        {/* Status Dropdown */}
        {showStatus && (
          <div className="mt-4 p-4 rounded-2xl border bg-white shadow-lg flex flex-wrap gap-3">
            {statusList.map((item, index) => (
              <Status
                key={index}
                value={item?.value}
                type={"product"}
                id={user?._id}
                feild={item?.field}
              />
            ))}
          </div>
        )}
      </td>

      {/* Actions */}
      <td className="px-6 py-5">
        <div className="flex items-center justify-center gap-3">
          {/* Edit */}
          <Link href={`/admin/product/edit/${user?.slug}`}>
            <button className="p-2.5 rounded-xl bg-blue-50 text-blue-600 hover:bg-blue-100 transition-all">
              <Pencil size={18} />
            </button>
          </Link>

          {/* View */}
          <Link href={`/admin/product/view/${user?._id}`}>
            <button className="p-2.5 rounded-xl bg-emerald-50 text-emerald-600 hover:bg-emerald-100 transition-all">
              <FaEye size={18} />
            </button>
          </Link>

          {/* Delete */}
          <DeleteBtn id={user?._id} type={"product"} />
        </div>
      </td>
    </tr>
  );
}
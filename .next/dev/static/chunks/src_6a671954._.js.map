"use client";
import Status from "@/app/components/admin components/Status";
import { Pencil, Trash2, Plus } from "lucide-react";
import React from "react";
import { fetchapi } from "@/api_call/api";

export default async function UserManagementTable() {

  const categories = await fetchapi()


  return (
    <div className="p-6">
      {/* Header */}
      <div className="flex items-center justify-between mb-6">
        <h1 className="text-2xl font-bold">User Management</h1>

        <button className="flex items-center gap-2 px-4 py-2 bg-orange-400 cursor-pointer text-white rounded-lg hover:scale-x-105 transition">
          <Plus size={18} />
          Add User
        </button>
      </div>

      {/* Table */}
      <div className="overflow-x-auto  rounded-xl">
        <table className="min-w-full text-left">
          <thead className="bg-gray-50 border-b">
            <tr>
              <th className="px-4 py-3 text-md font-medium text-gray-600">
                Name
              </th>
              <th className="px-4 py-3 text-md font-medium text-gray-600">
                Email
              </th>
              <th className="px-4 py-3 text-md font-medium text-gray-600">
                Role
              </th>
              <th className="px-4 py-3 text-md font-medium text-gray-600">
                Status
              </th>
              <th className="px-4 py-3 text-md font-medium text-gray-600">
                Actions
              </th>
            </tr>
          </thead>

          <tbody>
            {categories.map((user) => (
                <tr
                  key={user._id}
                  className="border-b text-md hover:bg-gray-50 transition"
                >
                  <td className="px-4 py-3 font-medium">{user.name}</td>
                  <td className="px-4 py-3 text-gray-600">{user.email}</td>
                  <td className="px-4 py-3">{user.role}</td>

                  <Status status = {user.status} id = {user._id} />

                  <td className="px-4 py-3">
                    <div className="flex items-center gap-3">
                      <button className="text-blue-600 hover:text-blue-800 transition">
                        <Pencil size={18} />
                      </button>

                      <button className="text-red-600 hover:text-red-800 transition">
                        <Trash2 size={18} />
                      </button>
                    </div>
                  </td>
                </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  );
}

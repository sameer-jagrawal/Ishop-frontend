"use client";

import Link from "next/link";
import { MapPin, Plus, Check } from "lucide-react";
import { useState } from "react";

export default function AddressPage() {

  const [selectedAddress, setSelectedAddress] = useState(1);

  const addresses = [
    {
      id: 1,
      name: "Mark Cole",
      phone: "+1 234 567 890",
      address:
        "4517 Washington Ave, Manchester, Kentucky 39495",
      type: "Home",
    },
    {
      id: 2,
      name: "Mark Cole",
      phone: "+1 987 654 321",
      address:
        "2118 Thornridge Cir, Syracuse, Connecticut 35624",
      type: "Office",
    },
  ];

  return (
    <div className="max-w-5xl mx-auto px-4 py-10 bg-gray-50 min-h-screen">

      {/* Header */}
      <div className="flex items-center justify-between mb-8">

        <div>
          <h1 className="text-3xl font-bold text-gray-800">
            Saved Addresses
          </h1>

          <p className="text-gray-500 mt-1">
            Select a delivery address
          </p>
        </div>

        {/* Add Address */}
        <Link
          href="/profile/address/add"
          className="flex items-center gap-2 bg-[#01A49E] text-white px-5 py-3 rounded-xl transition-all duration-300 hover:bg-[#01857f] hover:shadow-lg"
        >
          <Plus size={18} />
          Add Address
        </Link>

      </div>

      {/* Address List */}
      <div className="space-y-5">

        {addresses.map((item) => {

          const active = selectedAddress === item.id;

          return (

            <div
              key={item.id}
              onClick={() => setSelectedAddress(item.id)}
              className={`relative bg-white rounded-2xl p-5 border transition-all duration-300 cursor-pointer hover:shadow-md
              
              ${
                active
                  ? "border-[#01A49E] shadow-md"
                  : "border-gray-200 hover:border-[#01A49E]/40"
              }`}
            >

              {/* Radio */}
              <div className="absolute top-5 right-5">

                <div
                  className={`w-6 h-6 rounded-full border-2 flex items-center justify-center transition-all duration-300
                  
                  ${
                    active
                      ? "border-[#01A49E] bg-[#01A49E]"
                      : "border-gray-300"
                  }`}
                >
                  {active && (
                    <Check
                      size={14}
                      className="text-white"
                    />
                  )}
                </div>

              </div>

              {/* Content */}
              <div className="flex items-start gap-4">

                {/* Icon */}
                <div
                  className={`min-w-12 h-12 rounded-full flex items-center justify-center
                  
                  ${
                    active
                      ? "bg-[#01A49E]/10 text-[#01A49E]"
                      : "bg-gray-100 text-gray-500"
                  }`}
                >
                  <MapPin size={22} />
                </div>

                {/* Details */}
                <div className="pr-10">

                  {/* Type */}
                  <div className="flex items-center gap-3 mb-2">

                    <span className="text-sm font-medium bg-[#01A49E]/10 text-[#01A49E] px-3 py-1 rounded-full">
                      {item.type}
                    </span>

                  </div>

                  {/* Main Address */}
                  <p className="text-gray-800 leading-7 font-medium">

                    {item.name},{" "}
                    {item.phone},{" "}
                    {item.address}

                  </p>

                </div>

              </div>

            </div>

          );
        })}

      </div>
    </div>
  );
}